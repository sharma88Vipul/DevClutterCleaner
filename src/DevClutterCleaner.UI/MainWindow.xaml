<Window x:Class="DevClutterCleaner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DevClutterCleaner"
        Height="700"
        Width="1160"
        MinHeight="620"
        MinWidth="1020"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2933" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C6670" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D5DCE5" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="White" />
        <SolidColorBrush x:Key="RowAltBrush" Color="#F9FBFD" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="144" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource PrimaryPressedBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#AAB7C4" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#AAB7C4" />
                                <Setter Property="Foreground" Value="#F7FAFC" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18">
            <DockPanel>
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="DevClutterCleaner"
                           FontSize="25"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Developer cache scanner and cleanup planner"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Border DockPanel.Dock="Right"
                    Background="#ECFDF5"
                    BorderBrush="#A7F3D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                <TextBlock Text="Read-only scanner mode"
                           Foreground="{StaticResource SuccessBrush}"
                           FontWeight="SemiBold" />
            </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Margin="0,16,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ScanButton"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ScanButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ScanButtonIcon"
                                       Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="ScanButtonText"
                                       Text="Scan caches"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="PreviewCleanupButton"
                            Height="42"
                            MinWidth="154"
                            Padding="18,0"
                            Margin="12,0,0,0"
                            Click="PreviewCleanupButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Preview cleanup"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="CleanSelectedButton"
                            Height="42"
                            MinWidth="142"
                            Padding="18,0"
                            Margin="12,0,0,0"
                            Click="CleanSelectedButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Clean selected"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExportCsvButton"
                            Height="42"
                            MinWidth="126"
                            Padding="18,0"
                            Margin="12,0,0,0"
                            Click="ExportCsvButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="CSV"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExportHtmlButton"
                            Height="42"
                            MinWidth="126"
                            Padding="18,0"
                            Margin="12,0,0,0"
                            Click="ExportHtmlButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="HTML"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExportPdfButton"
                            Height="42"
                            MinWidth="126"
                            Padding="18,0"
                            Margin="12,0,0,0"
                            Click="ExportPdfButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="PDF"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="22,0,22,0"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ScanLoaderIcon"
                                   Text="&#xE895;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   RenderTransformOrigin="0.5,0.5"
                                   Visibility="Collapsed"
                                   Margin="0,0,8,0">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="ScanLoaderRotateTransform" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="ScanActivityText"
                                   Text="Ready"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock x:Name="CurrentFileText"
                               Text="No scan has been run yet."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="620"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Last scan"
                               Style="{StaticResource MetricLabelStyle}"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="LastScanHeaderText"
                               Text="Never"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Exclusions"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Excluded paths are blocked from cleanup preview and saved for future sessions."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,3,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ExclusionPathTextBox"
                                 MinHeight="30"
                                 VerticalContentAlignment="Center" />
                        <Button x:Name="AddExclusionButton"
                                Grid.Column="1"
                                Content="Add"
                                Width="94"
                                MinHeight="30"
                                Margin="10,0,0,0"
                                Click="AddExclusionButton_Click" />
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button x:Name="AddSelectedExclusionButton"
                                Content="Exclude selected target"
                                Width="188"
                                MinHeight="28"
                                Click="AddSelectedExclusionButton_Click"
                                IsEnabled="False" />
                        <Button x:Name="RemoveExclusionButton"
                                Content="Remove selected"
                                Width="150"
                                MinHeight="28"
                                Margin="10,0,0,0"
                                Click="RemoveExclusionButton_Click"
                                IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Saved exclusions"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="ExclusionsList"
                             MinHeight="92"
                             MaxHeight="122"
                             Margin="0,10,0,0"
                             SelectionChanged="ExclusionsList_SelectionChanged" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total reclaimable" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock x:Name="TotalReclaimableMetricText" Text="-" Style="{StaticResource MetricValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Targets scanned" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock x:Name="TargetsScannedMetricText" Text="0" Style="{StaticResource MetricValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Low-risk targets" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock x:Name="LowRiskMetricText" Text="0" Style="{StaticResource MetricValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Needs review" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock x:Name="NeedsReviewMetricText" Text="0" Style="{StaticResource MetricValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Last scan" Style="{StaticResource MetricLabelStyle}" />
                    <TextBlock x:Name="LastScanMetricText" Text="Never" Style="{StaticResource MetricValueStyle}" FontSize="16" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Scan results"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentScanText"
                                   Text="Ready to scan NuGet, npm, and Windows Temp."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <TextBlock x:Name="ScanCountText"
                               DockPanel.Dock="Right"
                               Text="0 / 3"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                </DockPanel>

                <ProgressBar x:Name="ScanProgressBar"
                             Height="5"
                             IsIndeterminate="False"
                             Visibility="Collapsed"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="#E8EDF3"
                             Margin="0,0,0,12" />

                <DataGrid x:Name="ResultsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E8EDF3"
                          RowBackground="White"
                          AlternatingRowBackground="{StaticResource RowAltBrush}"
                          Background="White"
                          BorderBrush="{StaticResource BorderBrushSoft}"
                          BorderThickness="1"
                          MinHeight="270"
                          MinRowHeight="42"
                          SelectionChanged="ResultsGrid_SelectionChanged"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Clean"
                                                Width="62">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelectedForCleanup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding CanSelectForCleanup}"
                                              Checked="CleanupSelection_Changed"
                                              Unchecked="CleanupSelection_Changed" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Target"
                                            Binding="{Binding Name}"
                                            IsReadOnly="True"
                                            Width="125" />
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            IsReadOnly="True"
                                            Width="120" />
                        <DataGridTextColumn Header="Current path"
                                            Binding="{Binding Path}"
                                            IsReadOnly="True"
                                            Width="260" />
                        <DataGridTextColumn Header="Exists"
                                            Binding="{Binding Exists}"
                                            IsReadOnly="True"
                                            Width="70" />
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size}"
                                            IsReadOnly="True"
                                            Width="90" />
                        <DataGridTextColumn Header="Risk"
                                            Binding="{Binding Risk}"
                                            IsReadOnly="True"
                                            Width="90" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            IsReadOnly="True"
                                            Width="130" />
                        <DataGridTemplateColumn Header="Recommendation"
                                                Width="360">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Recommendation}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="TotalReclaimableResultText"
                           Text="Total reclaimable space: Not scanned"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           Margin="0,12,0,0" />
                <TextBlock x:Name="StatusText"
                           Foreground="#8A1C1C"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="Cleanup uses explicit row selection, confirmation, and Recycle Bin move behavior."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,16,0,0" />
    </Grid>
    </ScrollViewer>
</Window>
